# Command Centre configuration
CC_PORT=8765
CC_PROJECT_ROOT=

# OTEL telemetry (set by setup_otel.py)
CLAUDE_CODE_ENABLE_TELEMETRY=1
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:8765
OTEL_EXPORTER_OTLP_PROTOCOL=http/json
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_LOG_TOOL_DETAILS=1

# Mission Control
MISSION_CONTROL_DEFAULT_MODEL=claude-sonnet-4-6
MC_MAX_CONCURRENT=3
MC_TASK_TIMEOUT=1800

# Telegram (optional - set by setup_telegram.py)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_DASH_CHAT_ID=
DASHBOARD_URL=http://127.0.0.1:8765

# Claude API (for skill routing)
# ANTHROPIC_API_KEY=

# Retry threshold (matches Claude Code default)
CLAUDE_CODE_MAX_RETRIES=10
